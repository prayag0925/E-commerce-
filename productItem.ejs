<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= product.name %> - Ecommerce</title>
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
  <%- include('partials/navbar') %>

  <div class="container">
    <div class="product-detail">
      <h2><%= product.name %></h2>
      <p><strong>Description:</strong> <%= product.description %></p>
      <p><strong>Price:</strong> Rs. <%= product.price %></p>
      <p><strong>Category:</strong> <%= product.category ? product.category.name : 'N/A' %></p>
      <p><strong>Added By:</strong> <%= product.addedBy ? product.addedBy.username : 'Unknown' %></p>

      <a href="/products" class="btn-back">&larr; Back to Products</a>
    </div>
  </div>
</body>
</html>
