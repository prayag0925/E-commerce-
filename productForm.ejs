<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= product ? 'Edit Product' : 'Add Product' %> - Ecommerce</title>
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
  <%- include('partials/navbar') %>

  <div class="form-page">
    <div class="form-container">
      <h2><%= product ? 'Edit Product' : 'Add New Product' %></h2>

      <form action="<%= product ? '/products/edit/' + product._id : '/products/add' %>" method="POST">
        <label for="name">Product Name</label>
        <input type="text" id="name" name="name" value="<%= product ? product.name : '' %>" required>

        <label for="description">Description</label>
        <textarea id="description" name="description" rows="4"><%= product ? product.description : '' %></textarea>

        <label for="price">Price (Rs.)</label>
        <input type="number" id="price" name="price" value="<%= product ? product.price : '' %>" min="0" required>

        <label for="category">Category</label>
        <select id="category" name="category" required>
          <option value="">-- Select Category --</option>
          <% categories.forEach(cat => { %>
            <option value="<%= cat._id %>"
              <%= (product && product.category && String(product.category) === String(cat._id)) ? 'selected' : '' %>>
              <%= cat.name %>
            </option>
          <% }) %>
        </select>

        <button type="submit" class="btn-submit"><%= product ? 'Update Product' : 'Add Product' %></button>
      </form>
    </div>
  </div>
</body>
</html>
